# Template pour configurer les variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles

# Gmail Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password

# Alternative: SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@smartnursery.com

# Alternative: Other SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@smartnursery.com

# Backend Configuration
BACKEND_URL=https://your-backend.com
EMAIL_ENDPOINT=https://your-cloud-function.cloudfunctions.net/sendOTP

# Firebase Configuration (attention: ne pas exposer les clés sensibles!)
FIREBASE_PROJECT_ID=smart-nursery-7a6f6

# Notes:
# - Utiliser App Passwords pour Gmail: https://support.google.com/accounts/answer/185833
# - SendGrid gratuit: https://sendgrid.com/free
# - Ne JAMAIS commiter ce fichier avec les vraies valeurs!
# - Copier en .env.local et remplir avec vos credentials
