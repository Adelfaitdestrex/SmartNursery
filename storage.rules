rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Images de profil : lecture publique, écriture par le propriétaire
    match /profile_images/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Visages enregistrés pour la reconnaissance faciale
    // Lecture publique nécessaire pour que le service Cloud Run puisse télécharger les images
    match /faces/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Images temporaires capturées lors du scan facial
    // Doivent être lisibles par le service Cloud Run (pas d'auth côté serveur)
    match /temp_faces/{filename} {
      allow read;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Autres fichiers : authentification requise
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}